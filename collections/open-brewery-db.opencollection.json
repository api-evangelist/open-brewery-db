{
  "opencollection": "1.0.0",
  "info": {
    "name": "Open Brewery DB",
    "version": "1.0.0"
  },
  "items": [
    {
      "info": {
        "name": "Breweries",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Open Brewery DB List Breweries",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.openbrewerydb.org/v1/breweries",
            "params": [
              {
                "name": "by_city",
                "value": "",
                "type": "query",
                "description": "Filter by city name."
              },
              {
                "name": "by_state",
                "value": "",
                "type": "query",
                "description": "Filter by state name (no abbreviations)."
              },
              {
                "name": "by_country",
                "value": "",
                "type": "query",
                "description": "Filter by country name."
              },
              {
                "name": "by_type",
                "value": "",
                "type": "query",
                "description": "Filter by brewery type."
              },
              {
                "name": "by_postal",
                "value": "",
                "type": "query",
                "description": "Filter by postal code."
              },
              {
                "name": "per_page",
                "value": "",
                "type": "query",
                "description": "Number of breweries per page (default 50, max 200)."
              },
              {
                "name": "page",
                "value": "",
                "type": "query",
                "description": "Page number for pagination."
              }
            ]
          },
          "docs": "Returns a list of breweries with optional filters."
        }
      ]
    },
    {
      "info": {
        "name": "Obdb",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Open Brewery DB Single Brewery",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.openbrewerydb.org/v1/breweries/:obdb-id",
            "params": [
              {
                "name": "obdb-id",
                "value": "",
                "type": "path",
                "description": "The ID of the brewery."
              }
            ]
          },
          "docs": "Get details of a single brewery by ID."
        }
      ]
    },
